{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "types": [],
    "paths": {
      "@bombom/shared/env": ["./src/env.ts"]
    }
  },
  "include": [
    "src/index.ts",
    "src/app.ts",
    "src/env.ts",
    "src/theme.ts",
    "src/webview.ts",
    "src/apis/index.ts",
    "src/types/index.ts",
    "src/utils/index.ts",
    "src/core/**/*"
  ],
  "exclude": ["node_modules", "dist"]
}
